<urn:concept:scribe:A1B2C3D4-0012-0012-0012-000000000012#v1>
    a scribe:Concept ;
    scribe:hasStatus    scribe:Active ;
    scribe:createdAt    "2026-05-04T00:00:00+00:00"^^xsd:dateTime ;
    scribe:modifiedAt   "2026-05-04T00:00:00+00:00"^^xsd:dateTime ;
    skos:prefLabel      "Diagramme illustrant les couches de KRVF"@fr ;
    skos:prefLabel      "KRVF layers diagram"@en ;
    skos:altLabel       "Diagramme KRVF"@fr ;
    skos:definition     """Diagramme conceptuel représentant l'architecture en couches du KRVF (Knowledge Representation & Visualization Framework). Ce diagramme illustre comment les différentes couches du cadre s'articulent pour produire des représentations de connaissances à la fois formellement rigoureuses et visuellement lisibles."""@fr ;
    skos:note           """Cette entité illustre le principe de récursion sujet/objet de Th3Sr1b3Pr0j3ct : KRVF (sujet) est représenté par ce diagramme (objet), qui est lui-même une entité documentable pouvant avoir ses propres représentations."""@fr .
